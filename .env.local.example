# ========================================
# LoopArchitect Frontend Environment Config
# ========================================
# Copy this file to .env.local and fill in actual values.
# .env.local is in .gitignore and should NEVER be committed.

# Backend API origin (server-side only – used by the Next.js API proxy route)
# Local development:   http://localhost:8000
# Railway staging:     https://web-staging-cb7b.up.railway.app
# Railway production:  https://web-production-3afc5.up.railway.app
#
# REQUIRED in Vercel environment variables for every deployment environment.
# Without this, the proxy will return a 500 error instead of silently routing
# to the wrong backend.
BACKEND_ORIGIN=http://localhost:8000

# Backend origin for direct browser-to-backend requests (e.g. file uploads).
# Must be set at Vercel build time so Next.js can inline it.
# Railway staging:     https://web-staging-cb7b.up.railway.app
# Railway production:  https://web-production-3afc5.up.railway.app
#
# REQUIRED in Vercel environment variables for every deployment environment.
NEXT_PUBLIC_BACKEND_ORIGIN=http://localhost:8000

# NOTE: NEXT_PUBLIC_API_URL is no longer required.
# All browser API calls are routed through the Next.js API proxy route at
# /api/[...path], which forwards them to BACKEND_ORIGIN on the server side.
# This avoids CORS issues because the browser never requests the backend
# origin directly at runtime.
